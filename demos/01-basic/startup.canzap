name: Engine startup checks
assertions:
  - name: rpm frame present
    id: 0x1A0
    present: true
    min_count: 3
  - name: brake released
    id: 0x2B1
    byte: 0
    equals: 0x00
  - name: heartbeat cadence
    id: 0x700
    present: true
    min_count: 5
    max_period_ms: 120
  - name: no diagnostic fault
    id: 0x500
    present: false
